{
  "Checkbox": {
    "size": {
      "md": {
        "control": {
          "$value": 20,
          "$type": "number"
        },
        "mark-width": {
          "$value": 10,
          "$type": "number"
        },
        "mark-height": {
          "$value": 8,
          "$type": "number"
        },
        "dash-height": {
          "$value": 1.75,
          "$type": "number"
        },
        "row-gap": {
          "$value": 8,
          "$type": "number"
        },
        "label-gap": {
          "$value": 8,
          "$type": "number"
        },
        "content-gap": {
          "$value": 4,
          "$type": "number"
        },
        "text-padding-y": {
          "$value": 3,
          "$type": "number"
        }
      }
    },
    "radius": {
      "$value": "{Radius/radius-xs}",
      "$type": "number"
    },
    "border-width": {
      "$value": 1,
      "$type": "number"
    },
    "focus-ring": {
      "width": {
        "$value": 3.75,
        "$type": "number"
      },
      "inner-width": {
        "$value": 1.25,
        "$type": "number"
      }
    },
    "color": {
      "bg": {
        "$value": "#FFFFFF",
        "$type": "color"
      },
      "border": {
        "$value": "#A1A1A4",
        "$type": "color"
      },
      "border-hover": {
        "$value": "#C9C9C9",
        "$type": "color"
      },
      "bg-checked": {
        "$value": "#2D2D2E",
        "$type": "color"
      },
      "bg-checked-hover": {
        "$value": "#5E5E5F",
        "$type": "color"
      },
      "mark": {
        "$value": "#FFFFFF",
        "$type": "color"
      },
      "border-error": {
        "$value": "var(--color-border-error)",
        "$type": "color"
      },
      "border-disabled": {
        "$value": "#C9C9C9",
        "$type": "color"
      },
      "bg-disabled-checked": {
        "$value": "#C9C9C9",
        "$type": "color"
      },
      "top-label": {
        "$value": "var(--color-text-primary)",
        "$type": "color"
      },
      "side-label": {
        "$value": "var(--color-text-primary)",
        "$type": "color"
      },
      "description": {
        "$value": "var(--color-text-secondary)",
        "$type": "color"
      },
      "top-label-disabled": {
        "$value": "var(--color-text-disabled)",
        "$type": "color"
      },
      "text-disabled": {
        "$value": "var(--color-text-disabled)",
        "$type": "color"
      },
      "error": {
        "$value": "var(--color-text-error)",
        "$type": "color"
      }
    },
    "typography": {
      "font-family": {
        "$value": "{Typography/Font family/body}",
        "$type": "string"
      },
      "label-font-size": {
        "$value": "{Typography/Font size/text-sm}",
        "$type": "number"
      },
      "label-line-height": {
        "$value": 14,
        "$type": "number"
      },
      "label-font-weight": {
        "$value": "{Typography/Font weight/medium}",
        "$type": "number"
      },
      "top-label-font-weight": {
        "$value": "{Typography/Font weight/semibold}",
        "$type": "number"
      },
      "description-font-size": {
        "$value": "{Typography/Font size/caption-sm}",
        "$type": "number"
      },
      "description-line-height": {
        "$value": 16,
        "$type": "number"
      },
      "description-font-weight": {
        "$value": "{Typography/Font weight/medium}",
        "$type": "number"
      }
    }
  }
}
