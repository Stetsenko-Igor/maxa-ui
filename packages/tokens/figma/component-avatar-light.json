        "$value": "{Color modes/background/bg-success-strong}",
        "$type": "color"
      },
      "offline": {
        "$value": "{Color modes/background/bg-neutral-strong}",
        "$type": "color"
      },
      "busy": {
        "$value": "{Color modes/background/bg-error-strong}",
        "$type": "color"
      },
      "away": {
        "$value": "{Color modes/background/bg-warning-strong}",
        "$type": "color"
      }
