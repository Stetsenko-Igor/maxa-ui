{
  "Avatar": {
    "surface": {
      "bg": {
        "$value": "{Color modes/background/bg-brand-subtle}",
        "$type": "color"
      },
      "text": {
        "$value": "{Color modes/text/text-brand}",
        "$type": "color"
      },
      "border": {
        "$value": "{Color modes/border/border-secondary}",
        "$type": "color"
      }
    },
    "layout": {
      "size-xs": {
        "$value": 24,
        "$type": "number"
      },
      "size-sm": {
        "$value": 32,
        "$type": "number"
      },
      "size-md": {
        "$value": 40,
        "$type": "number"
      },
      "size-lg": {
        "$value": 48,
        "$type": "number"
      },
      "size-xl": {
        "$value": 64,
        "$type": "number"
      },
      "radius-circle": {
        "$value": "{Radius/radius-full}",
        "$type": "number"
      },
      "radius-square": {
        "$value": "{Radius/radius-md}",
        "$type": "number"
      },
      "status-size-md": {
        "$value": 10,
        "$type": "number"
      },
      "group-overlap": {
        "$value": 10,
        "$type": "number"
      }
