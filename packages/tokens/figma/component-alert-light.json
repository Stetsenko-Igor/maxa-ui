{
  "Alert": {
    "layout": {
      "radius": {
        "$value": "{Radius/radius-md}",
        "$type": "number"
      },
      "padding-x": {
        "$value": 16,
        "$type": "number"
      },
      "padding-y": {
        "$value": 16,
        "$type": "number"
      },
      "gap": {
        "$value": 8,
        "$type": "number"
      },
      "content-gap": {
        "$value": 4,
        "$type": "number"
      },
      "action-gap": {
        "$value": 8,
        "$type": "number"
      }
    },
    "strip": {
      "width": {
        "$value": 4,
        "$type": "number"
      }
    },
    "icon": {
      "size": {
        "$value": 20,
        "$type": "number"
      }
    },
    "dismiss": {
      "size": {
        "$value": 32,
        "$type": "number"
      },
      "opacity": {
        "$value": 65,
        "$type": "number"
      }
    },
    "typography": {
      "font-family": {
        "$value": "{Typography/Font family/body}",
        "$type": "string"
      },
      "font-size": {
        "$value": "{Typography/Font size/text-md}",
        "$type": "string"
      },
      "line-height": {
        "$value": "{Typography/Line height/text-md}",
        "$type": "string"
      },
      "font-weight": {
        "$value": "{Typography/Font weight/medium}",
        "$type": "string"
      },
      "title-size": {
        "$value": "{Typography/Font size/text-lg}",
        "$type": "string"
      },
      "title-line-height": {
        "$value": "{Typography/Line height/text-lg}",
        "$type": "string"
      },
      "title-weight": {
        "$value": "{Typography/Font weight/bold}",
        "$type": "string"
      }
    },
    "color": {
      "info": {
        "bg": {
          "$value": "{Color modes/background/bg-info-subtle}",
          "$type": "color"
        },
        "border": {
          "$value": "{Color modes/border/border-secondary}",
          "$type": "color"
        },
        "accent": {
          "$value": "{Color modes/foreground/fg-info}",
          "$type": "color"
        },
        "text": {
          "$value": "{Color modes/text/text-primary}",
          "$type": "color"
        }
      },
      "success": {
        "bg": {
          "$value": "{Color modes/background/bg-success-subtle}",
          "$type": "color"
        },
        "border": {
          "$value": "{Color modes/border/border-secondary}",
          "$type": "color"
        },
        "accent": {
          "$value": "{Color modes/foreground/fg-positive}",
          "$type": "color"
        },
        "text": {
          "$value": "{Color modes/text/text-primary}",
          "$type": "color"
        }
      },
      "warning": {
        "bg": {
          "$value": "{Color modes/background/bg-warning-subtle}",
          "$type": "color"
        },
        "border": {
          "$value": "{Color modes/border/border-secondary}",
          "$type": "color"
        },
        "accent": {
          "$value": "{Color modes/foreground/fg-warning}",
          "$type": "color"
        },
        "text": {
          "$value": "{Color modes/text/text-primary}",
          "$type": "color"
        }
      },
      "danger": {
        "bg": {
          "$value": "{Color modes/background/bg-error-subtle}",
          "$type": "color"
        },
        "border": {
          "$value": "{Color modes/border/border-secondary}",
          "$type": "color"
        },
        "accent": {
          "$value": "{Color modes/foreground/fg-negative}",
          "$type": "color"
        },
        "text": {
          "$value": "{Color modes/text/text-primary}",
          "$type": "color"
        }
      },
      "neutral": {
        "bg": {
          "$value": "{Color modes/background/bg-neutral-subtle}",
          "$type": "color"
        },
        "border": {
          "$value": "{Color modes/border/border-secondary}",
          "$type": "color"
        },
        "accent": {
          "$value": "{Color modes/foreground/fg-secondary}",
          "$type": "color"
        },
        "text": {
          "$value": "{Color modes/text/text-primary}",
          "$type": "color"
        }
      },
      "emphasize": {
        "bg": {
          "$value": "{Color modes/background/bg-neutral-strong}",
          "$type": "color"
        },
        "border": {
          "$value": "{Color modes/border/border-primary}",
          "$type": "color"
        },
        "accent": {
          "$value": "{Color modes/foreground/fg-inverse}",
          "$type": "color"
        },
        "text": {
          "$value": "{Color modes/text/text-inverse}",
          "$type": "color"
        }
      }
    }
  }
}
