{
  "Alert": {
    "layout": {
      "radius": {
        "$value": "{Radius/radius-md}",
        "$type": "number"
      },
      "padding-x": {
        "$value": 16,
        "$type": "number"
      },
      "padding-y": {
        "$value": 16,
        "$type": "number"
      },
      "gap": {
        "$value": 8,
        "$type": "number"
      },
      "content-gap": {
        "$value": 4,
        "$type": "number"
      },
      "action-gap": {
        "$value": 8,
        "$type": "number"
      }
    },
    "strip": {
      "width": {
        "$value": 4,
        "$type": "number"
      }
    },
    "icon": {
      "size": {
        "$value": 20,
        "$type": "number"
      }
    },
    "dismiss": {
      "size": {
        "$value": 32,
        "$type": "number"
      },
      "opacity": {
        "$value": 65,
        "$type": "number"
      }
    },
    "typography": {
      "font-family": {
        "$value": "{Typography/Font family/body}",
        "$type": "string"
      },
      "font-size": {
        "$value": "{Typography/Font size/text-md}",
        "$type": "string"
      },
      "line-height": {
        "$value": "{Typography/Line height/text-md}",
        "$type": "string"
      },
      "font-weight": {
        "$value": "{Typography/Font weight/medium}",
        "$type": "string"
      },
      "title-size": {
        "$value": "{Typography/Font size/text-lg}",
        "$type": "string"
      },
      "title-line-height": {
        "$value": "{Typography/Line height/text-lg}",
        "$type": "string"
      },
      "title-weight": {
        "$value": "{Typography/Font weight/bold}",
        "$type": "string"
      }
    },
    "color": {
      "info": {
        "bg": {
          "$value": "#003877",
          "$type": "color"
        },
        "border": {
          "$value": "#0059C2",
          "$type": "color"
        },
        "accent": {
          "$value": "#54A3F6",
          "$type": "color"
        },
        "text": {
          "$value": "#F4F3F3",
          "$type": "color"
        }
      },
      "success": {
        "bg": {
          "$value": "#044329",
          "$type": "color"
        },
        "border": {
          "$value": "#006D0F",
          "$type": "color"
        },
        "accent": {
          "$value": "#2BB47D",
          "$type": "color"
        },
        "text": {
          "$value": "#F4F3F3",
          "$type": "color"
        }
      },
      "warning": {
        "bg": {
          "$value": "#521D00",
          "$type": "color"
        },
        "border": {
          "$value": "#B44E00",
          "$type": "color"
        },
        "accent": {
          "$value": "#E16D00",
          "$type": "color"
        },
        "text": {
          "$value": "#F4F3F3",
          "$type": "color"
        }
      },
      "error": {
        "bg": {
          "$value": "#7B0000",
          "$type": "color"
        },
        "border": {
          "$value": "#D71913",
          "$type": "color"
        },
        "accent": {
          "$value": "#FF755E",
          "$type": "color"
        },
        "text": {
          "$value": "#F4F3F3",
          "$type": "color"
        }
      },
      "neutral": {
        "bg": {
          "$value": "#2D2D2E",
          "$type": "color"
        },
        "border": {
          "$value": "#545454",
          "$type": "color"
        },
        "accent": {
          "$value": "#B7B7B7",
          "$type": "color"
        },
        "text": {
          "$value": "#F4F3F3",
          "$type": "color"
        }
      },
      "emphasize": {
        "bg": {
          "$value": "#292929",
          "$type": "color"
        },
        "border": {
          "$value": "#545454",
          "$type": "color"
        },
        "accent": {
          "$value": "#B7B7B7",
          "$type": "color"
        },
        "text": {
          "$value": "#F4F3F3",
          "$type": "color"
        }
      }
    }
  }
}
