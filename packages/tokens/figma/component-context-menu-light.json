    },
    "item-gap": {
      "$value": "var(--dropdown-menu-item-gap)",
      "$type": "string"
    },
    "item-text": {
      "$value": "var(--dropdown-menu-item-text)",
      "$type": "color"
    },
    "item-text-hover": {
      "$value": "var(--dropdown-menu-item-text-hover)",
      "$type": "color"
    },
    "item-text-disabled": {
      "$value": "var(--dropdown-menu-item-text-disabled)",
