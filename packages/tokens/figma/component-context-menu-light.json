    "bg": {
      "$value": "var(--dropdown-menu-bg)",
      "$type": "color"
    },
    "border": {
      "$value": "var(--dropdown-menu-border)",
      "$type": "color"
    },
    "radius": {
      "$value": "var(--dropdown-menu-radius)",
