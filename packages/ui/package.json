{
  "name": "@maxa/ui",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "pnpm --filter @maxa/ui^... build && node ../../scripts/clean-package-dist.mjs packages/ui && tsc --build --force && node ../../scripts/copy-css-assets.mjs packages/ui",
    "typecheck": "pnpm --filter @maxa/ui^... build && tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@maxa/tokens": "workspace:^",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@maxa/tokens": "workspace:^",
    "@types/react": "*",
    "@types/react-dom": "*",
    "@vitest/coverage-v8": "4.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "*",
    "vitest": "*",
    "vitest-axe": "^0.1.0"
  },
  "dependencies": {
    "@maxa/icons": "workspace:^",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.16",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1"
  }
}
