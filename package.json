{
  "name": "maxa-ui",
  "private": true,
  "version": "0.0.0",
  "engines": { "node": ">=20", "pnpm": ">=9" },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build":     "turbo run build",
    "dev":       "turbo run dev --parallel",
    "lint":      "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test":      "turbo run test",
    "format":    "prettier --write \"**/*.{ts,tsx,md,json,css}\""
  },
  "devDependencies": {
    "turbo":      "^2.0.0",
    "typescript": "^5.4.0",
    "prettier":   "^3.2.0",
    "eslint":     "^9.0.0"
  }
}
